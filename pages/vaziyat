  {q:"Sayrda ikki bola o'yinchoq uchun janjallashib qolishdi. Qanday hal qilasiz?",opts:["O'yinchoqni olib qo'yib, hech kimga bermayman","Ikkala bolani ham bir xil tarzda jazolayman","Ikkalasini tinglab, navbatma-navbat o'ynashni taklif qilaman","O'yinchoqni biriga berib, boshqasiga boshqa o'yinchoq beraman"],ans:2},
  {q:"Guruhdagi ikki bola doim bir-biri bilan janjallashib turadi. Siz qanday usul qo'llaysiz?",opts:["Har doim ularni bir-biridan uzoqroq o'tqazib qo'yaman","Har bir janjaldan keyin ikkalasini ham jazolayman","Kuzatib, hamkorlikdagi qiziqarli faoliyatga yo'naltiraman","Ota-onalariga muntazam shikoyat qilib boraman"],ans:2},
