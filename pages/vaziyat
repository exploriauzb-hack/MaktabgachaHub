<html lang="uz">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>MaktabgachaHub — Vaziyatlar</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f0f4ff;--surface:#fff;--border:#e5e7eb;--text:#111827;--muted:#6b7280;
  --accent:#1e40af;--accent-soft:#eff6ff;--accent-mid:#3b82f6;
  --green:#15803d;--green-soft:#f0fdf4;--amber:#b45309;--amber-soft:#fffbeb;
  --red:#b91c1c;--pro:#7c3aed;--pro-soft:#f5f3ff;--sidebar:240px;
}
body{font-family:'Inter',sans-serif;color:var(--text);font-size:14px;line-height:1.5;display:flex;min-height:100vh;background:#e8f0fe;position:relative;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;z-index:0;background:linear-gradient(160deg,#dbeafe 0%,#ede9fe 40%,#fce7f3 80%,#d1fae5 100%)}
#bg-canvas{position:fixed;inset:0;z-index:1;pointer-events:none}
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.35);z-index:20;backdrop-filter:blur(2px)}
.sidebar-overlay.show{display:block}
.sidebar{z-index:30;width:var(--sidebar);background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;height:100vh;overflow-y:auto;transition:transform .25s ease}
.sidebar-logo{padding:20px 20px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.logo-icon{width:32px;height:32px;background:var(--accent);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;flex-shrink:0}
.logo-text{font-size:13px;font-weight:600;color:var(--text);line-height:1.3}
.logo-text span{display:block;font-size:11px;font-weight:400;color:var(--muted)}
.sidebar-close{display:none;margin-left:auto;background:none;border:none;cursor:pointer;color:var(--muted);font-size:20px;padding:4px}
.sidebar-section{padding:12px 12px 4px;font-size:10px;font-weight:600;color:var(--muted);letter-spacing:.08em;text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:8px;margin:1px 8px;color:var(--muted);text-decoration:none;font-size:13px;font-weight:500;cursor:pointer;transition:background .15s,color .15s;position:relative}
.nav-item:hover{background:var(--bg);color:var(--text)}
.nav-item.active{background:var(--accent-soft);color:var(--accent)}
.nav-item i{font-size:16px;width:18px;text-align:center;flex-shrink:0}
.nav-item .badge{margin-left:auto;font-size:10px;font-weight:600;padding:2px 7px;border-radius:20px;background:var(--pro-soft);color:var(--pro)}
.nav-item .badge.soon{background:#f1f5f9;color:#94a3b8}
.sidebar-bottom{margin-top:auto;padding:12px;border-top:1px solid var(--border)}
.user-card{display:flex;align-items:center;gap:10px;padding:10px;border-radius:8px;background:var(--bg)}
.avatar{width:32px;height:32px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px;font-weight:600;flex-shrink:0}
.user-info .name{font-size:12px;font-weight:600}
.user-info .plan{font-size:11px;color:var(--muted)}
.btn-logout{display:flex;align-items:center;gap:6px;padding:7px 10px;border-radius:6px;border:1px solid var(--border);background:var(--surface);color:var(--muted);font-size:12px;font-weight:500;cursor:pointer;width:100%;margin-top:8px;transition:background .15s}
.btn-logout:hover{background:var(--bg);color:var(--red)}
.main{position:relative;z-index:2;margin-left:var(--sidebar);flex:1;padding:24px 28px;max-width:860px}
.topbar{display:flex;align-items:center;gap:12px;margin-bottom:24px}
.btn-hamburger{display:none;background:var(--surface);border:1px solid var(--border);border-radius:8px;width:38px;height:38px;align-items:center;justify-content:center;cursor:pointer;color:var(--text);font-size:20px;flex-shrink:0}
.btn-back{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;background:var(--surface);border:1px solid var(--border);border-radius:8px;color:var(--muted);font-size:13px;font-weight:500;text-decoration:none;transition:background .15s;white-space:nowrap}
.btn-back:hover{background:var(--bg);color:var(--text)}
.page-title{font-size:20px;font-weight:600}
.page-title span{color:var(--accent)}

/* INFO */
.info-box{background:var(--accent-soft);border:1px solid #bfdbfe;border-radius:10px;padding:12px 16px;font-size:12px;color:var(--accent);margin-bottom:20px;display:flex;align-items:center;gap:8px}
.info-box i{font-size:16px;flex-shrink:0}

/* QUIZ STATE */
.quiz-start{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:32px;text-align:center;margin-bottom:20px}
.quiz-start-icon{width:64px;height:64px;background:var(--accent-soft);border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;color:var(--accent);font-size:30px}
.quiz-start h2{font-size:18px;font-weight:700;margin-bottom:8px}
.quiz-start p{font-size:13px;color:var(--muted);margin-bottom:24px;line-height:1.6}
.quiz-meta{display:flex;gap:16px;justify-content:center;margin-bottom:24px;flex-wrap:wrap}
.quiz-meta-item{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--muted);background:var(--bg);padding:6px 12px;border-radius:8px;border:1px solid var(--border)}
.quiz-meta-item i{font-size:15px;color:var(--accent)}
.btn-start{display:inline-flex;align-items:center;gap:8px;padding:12px 28px;background:var(--accent);color:#fff;border:none;border-radius:9px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;transition:transform .15s}
.btn-start:hover{transform:translateY(-1px)}

/* QUIZ ACTIVE */
.quiz-active{display:none}
.quiz-progress-bar{height:5px;background:var(--bg);border-radius:99px;overflow:hidden;margin-bottom:20px}
.quiz-progress-fill{height:100%;background:var(--accent-mid);border-radius:99px;transition:width .3s}
.quiz-counter{display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--muted);margin-bottom:16px}
.quiz-counter strong{color:var(--text);font-size:14px}
.question-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px 24px;margin-bottom:16px}
.question-num{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px}
.question-text{font-size:15px;font-weight:600;line-height:1.6;color:var(--text)}
.options-list{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
.option-btn{display:flex;align-items:center;gap:12px;padding:12px 16px;background:var(--surface);border:1.5px solid var(--border);border-radius:10px;cursor:pointer;font-size:13px;font-family:inherit;color:var(--text);text-align:left;transition:border-color .15s,background .15s;width:100%}
.option-btn:hover:not(:disabled){border-color:#93c5fd;background:var(--accent-soft)}
.option-btn .opt-letter{width:24px;height:24px;border-radius:6px;background:var(--bg);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;color:var(--muted);flex-shrink:0;transition:background .15s,color .15s}
.option-btn.correct{border-color:var(--green);background:var(--green-soft)}
.option-btn.correct .opt-letter{background:var(--green);color:#fff}
.option-btn.wrong{border-color:var(--red);background:#fef2f2}
.option-btn.wrong .opt-letter{background:var(--red);color:#fff}
.option-btn.disabled{cursor:default;opacity:.7}
.feedback-box{padding:12px 16px;border-radius:10px;font-size:13px;font-weight:500;display:none;align-items:center;gap:8px;margin-bottom:16px}
.feedback-box.show{display:flex}
.feedback-box.ok{background:var(--green-soft);color:var(--green);border:1px solid #bbf7d0}
.feedback-box.err{background:#fef2f2;color:var(--red);border:1px solid #fecaca}
.feedback-box i{font-size:18px;flex-shrink:0}
.btn-next{display:flex;align-items:center;gap:7px;padding:11px 24px;background:var(--accent);color:#fff;border:none;border-radius:9px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;transition:transform .15s}
.btn-next:hover{transform:translateY(-1px)}

/* RESULT */
.quiz-result{display:none;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:32px;text-align:center}
.result-icon{width:72px;height:72px;border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:32px}
.result-score{font-size:48px;font-weight:700;margin-bottom:4px}
.result-label{font-size:14px;color:var(--muted);margin-bottom:24px}
.result-stats{display:flex;gap:12px;justify-content:center;margin-bottom:24px;flex-wrap:wrap}
.result-stat{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:12px 20px;text-align:center}
.result-stat .sv{font-size:20px;font-weight:700}
.result-stat .sl{font-size:11px;color:var(--muted);margin-top:2px}
.btn-retry{display:inline-flex;align-items:center;gap:7px;padding:11px 24px;background:var(--accent);color:#fff;border:none;border-radius:9px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;margin-right:8px}
.btn-dash{display:inline-flex;align-items:center;gap:7px;padding:11px 24px;background:var(--surface);color:var(--muted);border:1px solid var(--border);border-radius:9px;font-size:13px;font-weight:500;cursor:pointer;font-family:inherit;text-decoration:none}

.fab-back{position:fixed;bottom:28px;right:28px;z-index:100;display:flex;align-items:center;gap:8px;padding:12px 18px;background:var(--accent);color:#fff;border:none;border-radius:50px;font-family:'Inter',sans-serif;font-size:13px;font-weight:600;cursor:pointer;box-shadow:0 4px 20px rgba(30,64,175,.35);transition:transform .2s;text-decoration:none}
.fab-back:hover{transform:translateY(-3px)}

@media(max-width:768px){
  .sidebar{transform:translateX(-100%)}
  .sidebar.open{transform:translateX(0)}
  .sidebar-close{display:flex}
  .btn-hamburger{display:flex}
  .main{margin-left:0;padding:14px 14px 80px}
  .page-title{font-size:16px}
  .question-text{font-size:14px}
}
</style>
</head>
