<script>
(function(){
  const c=document.getElementById('bg-canvas'),ctx=c.getContext('2d');
  let W,H;
  function resize(){W=c.width=window.innerWidth;H=c.height=window.innerHeight}
  resize();window.addEventListener('resize',resize);
  const types=['star','heart','circle','flower'];
  const colors=['#93c5fd','#c4b5fd','#fdba74','#86efac','#f9a8d4','#fde68a'];
  function rnd(a,b){return a+Math.random()*(b-a)}
  const shapes=[];
  for(let i=0;i<22;i++)shapes.push({t:types[Math.floor(Math.random()*types.length)],color:colors[Math.floor(Math.random()*colors.length)],size:rnd(12,28),x:rnd(0,1)*window.innerWidth,y:rnd(0,1)*window.innerHeight,vx:rnd(-0.3,0.3),vy:rnd(-0.35,-0.1),rot:rnd(0,Math.PI*2),vrot:rnd(-0.008,0.008),op:rnd(0.12,0.32)});
  function drawStar(ctx,cx,cy,r,col,op){ctx.save();ctx.globalAlpha=op;ctx.fillStyle=col;ctx.beginPath();for(let i=0;i<5;i++){const a=Math.PI/2+i*Math.PI*2/5,ia=a+Math.PI/5;i===0?ctx.moveTo(cx+r*Math.cos(a),cy-r*Math.sin(a)):ctx.lineTo(cx+r*Math.cos(a),cy-r*Math.sin(a));ctx.lineTo(cx+(r*.45)*Math.cos(ia),cy-(r*.45)*Math.sin(ia))}ctx.closePath();ctx.fill();ctx.restore()}
  function drawHeart(ctx,cx,cy,r,col,op){ctx.save();ctx.globalAlpha=op;ctx.fillStyle=col;ctx.beginPath();ctx.moveTo(cx,cy+r*.5);ctx.bezierCurveTo(cx-r,cy-r*.3,cx-r*1.3,cy+r*.4,cx,cy+r*1.2);ctx.bezierCurveTo(cx+r*1.3,cy+r*.4,cx+r,cy-r*.3,cx,cy+r*.5);ctx.closePath();ctx.fill();ctx.restore()}
  function frame(){
    ctx.clearRect(0,0,W,H);
    shapes.forEach(s=>{
      s.x+=s.vx;s.y+=s.vy;s.rot+=s.vrot;
      if(s.y<-60){s.y=H+40;s.x=rnd(0,W)}
      if(s.x<-60)s.x=W+40;if(s.x>W+60)s.x=-40;
      ctx.save();ctx.translate(s.x,s.y);ctx.rotate(s.rot);
      if(s.t==='star')drawStar(ctx,0,0,s.size,s.color,s.op);
      else if(s.t==='heart')drawHeart(ctx,0,0,s.size*.7,s.color,s.op);
      else{ctx.globalAlpha=s.op;ctx.fillStyle=s.color;ctx.beginPath();ctx.arc(0,0,s.size*.6,0,Math.PI*2);ctx.fill()}
      ctx.restore();
    });
    requestAnimationFrame(frame);
  }
  frame();
})();
</script>

