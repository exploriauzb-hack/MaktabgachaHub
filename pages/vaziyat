  {q:"6 yoshli bola maktabga borishdan qo'rqishini aytadi. Sizning ishingiz?",opts:["«Qo'rqma, hamma boradi» deb qisqa javob beraman","Ota-onasiga murojaat qilib, ular hal qilishini so'rayman","Bolani maktab hayoti bilan ijobiy misollar orqali tanishtirib, qiziqish uyg'otaman","«Hali vaqt bor» deb, mavzuni kechiktiraman"],ans:2},
  {q:"Tarbiyachi sifatida siz o'zingizning kasbiy xatongizni sezib qoldingiz. Bolalar oldida qanday ish qilasiz?",opts:["Xatoni yashirib, boshqa mavzuga o'tib ketaman","Xatoni tan olib, to'g'rilayman va bolalardan kechirim so'rayman","Boshqa tarbiyachini ayblab, o'zimni oqlayman","Xatoni tuzataman, lekin tan olmayman"],ans:1},
];

const LETTERS=['A','B','C','D'];
let cur=0,correct=0,answered=false;

function startQuiz(){
  cur=0;correct=0;answered=false;
  document.getElementById('quizStart').style.display='none';
  document.getElementById('quizResult').style.display='none';
  document.getElementById('quizActive').style.display='block';
  renderQuestion();
}

function renderQuestion(){
  const q=QUESTIONS[cur];
  answered=false;
  document.getElementById('progressFill').style.width=((cur/30)*100)+'%';
  document.getElementById('qCounter').textContent=(cur+1)+' / 30';
  document.getElementById('qScore').textContent=correct+' to\'g\'ri';
  document.getElementById('qNum').textContent='Savol '+(cur+1);
  document.getElementById('qText').textContent=q.q;
  const fb=document.getElementById('feedbackBox');
  fb.className='feedback-box';fb.style.display='';
  document.getElementById('btnNext').style.display='none';
  const list=document.getElementById('optionsList');
  list.innerHTML='';
  q.opts.forEach((o,i)=>{
    const btn=document.createElement('button');
    btn.className='option-btn';
    btn.innerHTML=`<span class="opt-letter">${LETTERS[i]}</span><span>${o}</span>`;
    btn.onclick=()=>selectAnswer(i);
    list.appendChild(btn);
  });
}

function selectAnswer(idx){
  if(answered)return;
  answered=true;
  const q=QUESTIONS[cur];
  const btns=document.querySelectorAll('.option-btn');
  btns.forEach(b=>b.disabled=true);
  const fb=document.getElementById('feedbackBox');
  if(idx===q.ans){
    correct++;
    btns[idx].classList.add('correct');
    fb.className='feedback-box ok show';
    document.getElementById('feedbackIcon').className='ti ti-circle-check';
    document.getElementById('feedbackText').textContent='To\'g\'ri javob!';
  } else {
    btns[idx].classList.add('wrong');
    btns[q.ans].classList.add('correct');
    fb.className='feedback-box err show';
    document.getElementById('feedbackIcon').className='ti ti-circle-x';
    document.getElementById('feedbackText').textContent='Noto\'g\'ri. To\'g\'ri javob: '+LETTERS[q.ans];
  }
  document.getElementById('qScore').textContent=correct+' to\'g\'ri';
  const btn=document.getElementById('btnNext');
  btn.style.display='flex';
  document.getElementById('btnNextLabel').textContent=cur<29?'Keyingi savol':'Natijani ko\'rish';
}

function nextQuestion(){
  cur++;
  if(cur>=30){showResult();return;}
  renderQuestion();
}

function showResult(){
  document.getElementById('quizActive').style.display='none';
  const pct=Math.round((correct/30)*100);
  const xp=correct*10;
  const res=document.getElementById('quizResult');
  res.style.display='block';
  let icon,color,label;
  if(pct>=80){icon='ti-trophy';color='var(--green)';label='Ajoyib natija! Siz professional tarbiyachisiz.'}
  else if(pct>=60){icon='ti-thumb-up';color='var(--amber)';label='Yaxshi natija! Yana biroz mashq qiling.'}
  else{icon='ti-refresh';color='var(--red)';label='Ko\'proq mashq qilish kerak. Qayta ishlab ko\'ring.'}
  document.getElementById('resultIcon').innerHTML=`<i class="ti ${icon}" style="font-size:32px;color:${color}"></i>`;
  document.getElementById('resultIcon').style.background=color==='var(--green)'?'var(--green-soft)':color==='var(--amber)'?'var(--amber-soft)':'#fef2f2';
  document.getElementById('resultScore').textContent=pct+'%';
  document.getElementById('resultScore').style.color=color;
  document.getElementById('resultLabel').textContent=label;
  document.getElementById('rCorrect').textContent=correct;
  document.getElementById('rWrong').textContent=30-correct;
  document.getElementById('rXP').textContent='+'+xp;
  // XP saqlash
  if(typeof _sb!=='undefined'&&typeof _currentUser!=='undefined'&&_currentUser){
    _sb.from('profiles').select('xp').eq('id',_currentUser.id).single().then(({data})=>{
      const newXp=(data?.xp||0)+xp;
      _sb.from('profiles').update({xp:newXp}).eq('id',_currentUser.id);
    });
    _sb.from('test_results').insert({user_id:_currentUser.id,test_name:'Vaziyatli test',category:'vaziyat',score:correct,total:30,percentage:pct});
  }
}

function restartQuiz(){
  document.getElementById('quizResult').style.display='none';
  startQuiz();
}
</script>

