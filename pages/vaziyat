  {q:"5 yoshli bola doim o'z xatolarini tan olmaydi, boshqalarni ayblaydi. Siz qanday yo'l tutasiz?",opts:["Xatosi isbotlaganda, uni hamma oldida tan olishga majburlayman","«Xato qilish odatiy» deb, o'z xatolarimni tan olishga misol ko'rsataman","Bu xususiyatiga e'tibor bermay, o'tib ketaman","Ota-onasiga aytib, ular tarbiyalasin"],ans:1},
  {q:"Guruhda bola biror narsani yasashda qiynalib, yig'lay boshladi. Sizning harakatingiz?",opts:["«Yig'lama, qayta boshlaymiz» deb yupatib, yana bajarishga undayman","O'zi yasab berib, bolaga tayyor holatda beraman","Yoniga borib, «Nima bo'ldi?» deb so'rab, birgalikda yechim topaman","Boshqa bola yasasin, bu esa tomosha qilsin"],ans:2},
  {q:"O'yin davomida bola o'rtog'ining ismini noto'g'ri aytib, uni xafa qiladi. Siz nima qilasiz?",opts:["Noto'g'ri aytgan bolani jazolab, nomni to'g'ri aytishga majburlayman","Xafa bo'lgan bolani yupatib, boshqasiga «To'g'ri ayting» deb tushuntiraman","Ikkalasiga ham «Bu katta muammo emas» deyman","Bu holatga aralashmayman"],ans:1},
  {q:"Ekskursiya vaqtida bir bola guruhdan ajralib qolib, yo'qoladi. Sizning birinchi harakatingiz?",opts:["Barcha bolalarni joyida qoldirib, o'zim qidirib boraman","Qolgan bolalarni xavfsiz joyga to'plab, boshqa kattalardan yordam so'rab qidiraman","Vahimaga tushib, barcha bolalarni orqaga qaytaraman","Qolgan bolalarni qo'riqchiga topshirib, o'zim qidirishga ketaman"],ans:1},
  {q:"Guruhda bolalardan biri ota-onasining ajrashganini aytib, yig'laydi. Siz qanday munosabat bildirasiz?",opts:["«Bu kattalarning ishi, senga aloqasi yo'q» deb rad javob beraman","Quchoqlab, yupatib, «Men seni tushunaman» deb, qiziqarli faoliyatga yo'naltiraman","Bu haqida boshqa bolalar oldida gapirmaslikni aytaman","Psixologga yuborib, o'zim aralashmayman"],ans:1},
  {q:"Bola mashg'ulotda noto'g'ri javob berganida boshqa bolalar kulishadi. Siz nima qilasiz?",opts:["Kulgan bolalarni jazolab, noto'g'ri javob berganni himoya qilaman","«Xatolarni tuzatamiz» deb, bolalarni birgalikda to'g'ri javob topishga undayman","Javob bergan bola xijolat bo'lsa ham, davom etaman","Boshqa savolga o'tib, shu mavzuni unutaman"],ans:1},
